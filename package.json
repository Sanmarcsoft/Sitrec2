{
  "name": "sitrec",
  "version": "1.0.0",
  "scripts": {
    "test": "npx jest tests/",
    "test-regression": "npx jest tests_regression/",
    "test-all": "npx jest",
    "test-misb": "node ../test-all-misb-files.js",
    "check-three-imports": "node scripts/check-three-imports.js",
    "start": "npx webpack serve --config webpack.dev.js",
    "build": "npx webpack --config webpack.dev.js",
    "deploy": "npx webpack --config webpack.prod.js",
    "copy": "npx webpack --config webpack.copy-files.js",
    "build-standalone": "npx webpack --config webpack.standalone.js",
    "build-standalone-debug": "npx webpack --config webpack.standalone.js --mode development",
    "start-standalone": "node standalone-server.js",
    "start-standalone-debug": "node --inspect standalone-server.js",
    "dev-standalone": "npm run build-standalone && npm run start-standalone",
    "dev-standalone-debug": "npm run build-standalone-debug && npm run start-standalone-debug",
    "build-serverless": "npx webpack --config webpack.serverless.js --mode production",
    "build-serverless-debug": "npx webpack --config webpack.serverless.js --mode development",
    "start-serverless": "node standalone-serverless.js",
    "start-serverless-debug": "node --inspect standalone-serverless.js",
    "dev-serverless": "npm run build-serverless && npm run start-serverless",
    "dev-serverless-debug": "npm run build-serverless-debug && npm run start-serverless-debug",
    "version": "node -e \"console.log(require('child_process').execSync('git describe --tags --abbrev=0', {encoding: 'utf8'}).trim())\""
  },
  "jest": {
    "testPathIgnorePatterns": [
      "<rootDir>/test/"
    ],
    "roots": [
      "<rootDir>"
    ]
  },
  "dependencies": {
    "astronomy-engine": "^2.1.19",
    "buffer": "^6.0.3",
    "geotiff": "^2.1.3",
    "js-md5": "^0.8.3",
    "json-stringify-pretty-compact": "^4.0.0",
    "jszip": "^3.10.1",
    "mathjs": "^14.6.0",
    "ndarray": "^1.0.19",
    "satellite.js": "^6.0.1",
    "seedrandom": "^3.0.5",
    "stats.js": "^0.17.0",
    "three": "^0.179.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.3",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/preset-env": "^7.28.3",
    "@biomejs/biome": "2.2.2",
    "@wasm-tool/wasm-pack-plugin": "^1.7.0",
    "babel-jest": "^30.1.1",
    "babel-loader": "^10.0.0",
    "circular-dependency-plugin": "^5.2.2",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "dotenv-webpack": "^8.1.1",
    "express": "^4.21.2",
    "fs-extra": "^11.3.1",
    "html-webpack-plugin": "^5.6.4",
    "http-proxy-middleware": "^3.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.4",
    "jest-image-snapshot": "^6.5.1",
    "markdown-it": "^14.1.0",
    "mini-css-extract-plugin": "^2.9.4",
    "puppeteer": "^24.17.1",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.2",
    "webpack": "5.101.3",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2",
    "webpack-merge": "^6.0.1"
  }
}

